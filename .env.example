# ============================================
# Micro Automation — Environment Variables
# ============================================
# Copy this file to .env (backend) and web/.env.local (frontend)
# NEVER commit actual secrets to git

# -- Backend (FastAPI) --
# Auth is ON by default (secure). Set to true for local development:
AUTH_DISABLED=true
ALLOWED_EMAILS=your-email@gmail.com,operator@microembroidery.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# -- Frontend (Next.js / web/.env.local) --
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=same-secret-as-backend
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_TRUST_HOST=true

# -- API URL (frontend needs to know where backend is) --
NEXT_PUBLIC_API_URL=https://your-api.railway.app
